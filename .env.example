# ── AI Provider Selection ──────────────────────────────
# Transcription provider: local, openai, ollama, gemini
TRANSCRIPTION_PROVIDER=local
# Sentiment provider: local, openai, ollama, gemini
SENTIMENT_PROVIDER=local

# ── OpenAI ─────────────────────────────────────────────
# Required when provider=openai for either transcription or sentiment
# Get your key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# Transcription model: whisper-1 (default)
# Sentiment model: gpt-4o-mini (default), gpt-4o, etc.
# TRANSCRIPTION_API_KEY=
# SENTIMENT_API_KEY=
# TRANSCRIPTION_API_URL=
# SENTIMENT_API_URL=

# ── Ollama (local) ─────────────────────────────────────
# Required when provider=ollama for either transcription or sentiment
# Install Ollama: https://ollama.com
# Pull a whisper model for transcription: ollama pull whisper
# Pull a chat model for sentiment: ollama pull llama3.2
# Default URL: http://localhost:11434
# TRANSCRIPTION_API_URL=http://localhost:11434
# SENTIMENT_API_URL=http://localhost:11434
# TRANSCRIPTION_API_MODEL=whisper
# SENTIMENT_API_MODEL=llama3.2

# ── Google Gemini ──────────────────────────────────────
# Required when provider=gemini for either transcription or sentiment
# Get your key at https://aistudio.google.com/apikey
# Default URL: https://generativelanguage.googleapis.com/v1
# Default model: models/gemini-2.0-flash-001
# TRANSCRIPTION_API_KEY=AIza...
# SENTIMENT_API_KEY=AIza...
# TRANSCRIPTION_API_URL=
# SENTIMENT_API_URL=

# ── SIPREC Server ────────────────────────────────────
SIP_LISTEN_HOST=0.0.0.0
SIP_LISTEN_PORT=5060

# ── RTP ─────────────────────────────────────────────
RTP_LISTEN_HOST=0.0.0.0
RTP_MIN_PORT=10000
RTP_MAX_PORT=10100

# ── API ──────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# API key for authentication. All API requests must include X-API-Key header.
# Leave empty to disable authentication.
API_KEY=

# ── Whisper (local provider only) ──────────────────────
# Model size: tiny, base, small, medium, large-v3
# Downloaded automatically on first run (~1.5 GB for base)
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=auto
WHISPER_CACHE_DIR=

# ── Sentiment Model (local provider only) ──────────────
# Multilingual (Thai + English): cardiffnlp/twitter-xlm-roberta-base-sentiment
# English emotion: j-hartmann/emotion-english-distilroberta-base
SENTIMENT_MODEL=cardiffnlp/twitter-xlm-roberta-base-sentiment

# Sentiment label → score mapping (JSON)
# For multilingual (3 labels):
SENTIMENT_MAPPING={"negative":8.0, "neutral":1.0, "positive":1.0}
# For English emotion (7 labels):
# SENTIMENT_MAPPING={"anger":10, "disgust":8, "fear":7, "sadness":5, "surprise":4, "joy":1, "neutral":1}

HF_CACHE_DIR=

# ── Feature Toggles ──────────────────────────────────
TRANSCRIPTION_ENABLED=true
SENTIMENT_ENABLED=true

# ── Storage ─────────────────────────────────────────
OUTPUT_DIR=recordings
RETENTION_YEARS=7
INDEX_DB=index.db
