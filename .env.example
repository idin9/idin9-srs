# ── idin9-srs Configuration Reference ──────────────────
# Copy this file to .env and fill in your values.
# .env is NOT committed to version control — secrets stay local.

# ═══════════════════════════════════════════════════════
# REQUIRED SECRETS (MUST set in production .env)
# ═══════════════════════════════════════════════════════
# JWT secret for authentication tokens.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# JWT_SECRET=

# Encryption password for AES-256 at-rest recording encryption.
# Must be set if ENCRYPTION_ENABLED=true (the default).
# ENCRYPTION_PASSWORD=

# ── AI Provider Selection ──────────────────────────────
# Transcription provider: local, openai, ollama, gemini
TRANSCRIPTION_PROVIDER=local
# Sentiment provider: local, openai, ollama, gemini
SENTIMENT_PROVIDER=local

# ── OpenAI ─────────────────────────────────────────────
# Required when provider=openai for either transcription or sentiment
# TRANSCRIPTION_API_KEY=sk-...
# SENTIMENT_API_KEY=sk-...
# TRANSCRIPTION_API_URL=
# SENTIMENT_API_URL=

# ── Ollama (local) ─────────────────────────────────────
# TRANSCRIPTION_API_URL=http://localhost:11434
# SENTIMENT_API_URL=http://localhost:11434
# TRANSCRIPTION_API_MODEL=whisper
# SENTIMENT_API_MODEL=llama3.2

# ── Google Gemini ──────────────────────────────────────
# TRANSCRIPTION_API_KEY=AIza...
# SENTIMENT_API_KEY=AIza...
# TRANSCRIPTION_API_URL=
# SENTIMENT_API_URL=

# ── Server ─────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
SIP_LISTEN_HOST=0.0.0.0
SIP_LISTEN_PORT=5060

# ── RTP ────────────────────────────────────────────────
RTP_LISTEN_HOST=0.0.0.0
RTP_MIN_PORT=7000
RTP_MAX_PORT=7399

# ── Authentication ─────────────────────────────────────
# Auth mode: local, api_key, both
AUTH_MODE=local
# API key for authentication (if AUTH_MODE is api_key or both).
# NOTE: Empty key + auth_mode=api_key will block ALL access.
API_KEY=

# ── Regional & Display ────────────────────────────────
TIMEZONE=UTC
LOCALE=en_US
FONT_FAMILY=system

# ── Whisper (local provider only) ──────────────────────
# Model size: tiny, base, small, medium, large-v3
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=auto
WHISPER_CACHE_DIR=

# ── Sentiment Model (local provider only) ──────────────
# Multilingual (Thai+English): cardiffnlp/twitter-xlm-roberta-base-sentiment
# English emotion: j-hartmann/emotion-english-distilroberta-base
SENTIMENT_MODEL=cardiffnlp/twitter-xlm-roberta-base-sentiment

# Sentiment label → score mapping (JSON)
SENTIMENT_MAPPING={"negative":8.0, "neutral":1.0, "positive":1.0}
# For English emotion (7 labels):
# SENTIMENT_MAPPING={"anger":10, "disgust":8, "fear":7, "sadness":5, "surprise":4, "joy":1, "neutral":1}

HF_CACHE_DIR=

# ── Feature Toggles ──────────────────────────────────
TRANSCRIPTION_ENABLED=true
SENTIMENT_ENABLED=true

# ── Session Timeout ───────────────────────────────────
# Auto-stop sessions after N seconds of no RTP activity (0 = disabled)
SESSION_TIMEOUT_SECONDS=300

# ── Storage & Security ───────────────────────────────
OUTPUT_DIR=recordings
AUDIO_FORMAT=opus
ENCRYPTION_ENABLED=true
ENCRYPTION_PASSWORD=
RETENTION_YEARS=7
INDEX_DB=index.db
